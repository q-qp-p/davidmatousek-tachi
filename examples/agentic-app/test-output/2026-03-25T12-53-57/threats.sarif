            "findingId/v1": "S-3"
          }
        },
        {
          "ruleId": "tachi/stride/spoofing",
          "message": {
            "text": "An attacker may spoof the MCP Tool Server's identity when returning tool results because response authenticity is not verified, enabling injection of fabricated tool results.",
            "markdown": "Implement response signing on all MCP Tool Server responses using HMAC-SHA256. The Orchestrator must validate response signatures before processing tool results."
          },
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "examples/agentic-app/test-output/2026-03-25T12-53-57/threats.md" },
