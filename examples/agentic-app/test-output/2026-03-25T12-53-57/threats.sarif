          "ruleId": "tachi/stride/spoofing",
          "message": { "text": "Attacker may impersonate a legitimate user by stealing or forging authentication credentials to submit prompts and queries to the Guardrails Service.", "markdown": "Implement multi-factor authentication for user sessions; bind session tokens to client fingerprints using DPoP or certificate-bound tokens; enforce token expiration with sliding window of 15 minutes." },
          "level": "error",
          "locations": [{ "physicalLocation": { "artifactLocation": { "uri": "examples/agentic-app/architecture.md" }, "region": { "startLine": 1 } }, "logicalLocations": [{ "name": "User", "fullyQualifiedName": "User Zone/User", "kind": "external-entity" }] }],
