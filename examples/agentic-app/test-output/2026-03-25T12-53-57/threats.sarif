          "level": "error",
          "locations": [{ "physicalLocation": { "artifactLocation": { "uri": "examples/agentic-app/architecture.md" }, "region": { "startLine": 1 } }, "logicalLocations": [{ "name": "Guardrails Service", "fullyQualifiedName": "Application Zone/Guardrails Service", "kind": "process" }] }],
