            "residual-risk": "7.2",
            "maestro-layer": "L1 — Foundation Model",
            "recommendation": "Implement input validation to detect direct prompt injection patterns. Combine structural checks (reject injection markers, role-override syntax, encoded payloads) with model-based classification (Prompt-Guard, adversarial-trained classifier). Apply BEFORE prompt reaches Orchestrator LLM.",
            "effort-estimate": "Medium"
          }
        },
        {
          "ruleId": "tachi/ai/llm",
          "message": {"text": "Client-side XSS via LLM response rendered in browser [Control: missing]"},
          "level": "error",
