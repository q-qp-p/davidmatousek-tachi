            "inherent-risk": "7.2",
            "residual-risk": "7.2",
            "maestro-layer": "L1 — Foundation Model",
            "recommendation": "Implement per-session scoped permissions enforced by the Tool Server and KB independently. Determine session's permitted tool set and KB scope at authentication time. Apply step-up authentication for high-privilege operations.",
            "effort-estimate": "High"
          }
        },
        {
