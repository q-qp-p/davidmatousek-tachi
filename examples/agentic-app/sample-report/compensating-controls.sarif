{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "tachi-control-analyzer",
          "version": "1.0",
          "semanticVersion": "1.0",
          "informationUri": "https://github.com/davidmatousek/tachi",
          "rules": [
            {
              "id": "tachi/stride/spoofing",
              "name": "Spoofing",
              "shortDescription": {"text": "Identity spoofing threats (STRIDE-S)"},
              "properties": {"security-severity": "7.9"}
            },
            {
              "id": "tachi/stride/tampering",
              "name": "Tampering",
              "shortDescription": {"text": "Data/message tampering threats (STRIDE-T)"},
              "properties": {"security-severity": "5.8"}
            },
            {
              "id": "tachi/stride/repudiation",
              "name": "Repudiation",
              "shortDescription": {"text": "Non-repudiation gaps (STRIDE-R)"},
              "properties": {"security-severity": "5.7"}
            },
            {
              "id": "tachi/stride/info-disclosure",
              "name": "Information Disclosure",
              "shortDescription": {"text": "Sensitive-data exposure threats (STRIDE-I)"},
              "properties": {"security-severity": "5.5"}
            },
            {
              "id": "tachi/stride/denial-of-service",
              "name": "Denial of Service",
              "shortDescription": {"text": "Availability threats (STRIDE-D)"},
              "properties": {"security-severity": "6.6"}
            },
            {
              "id": "tachi/stride/privilege-escalation",
              "name": "Privilege Escalation",
              "shortDescription": {"text": "Elevation-of-privilege threats (STRIDE-E)"},
              "properties": {"security-severity": "7.3"}
            },
            {
              "id": "tachi/ai/agentic",
              "name": "Agentic",
              "shortDescription": {"text": "Agent-autonomy / tool-abuse threats"},
              "properties": {"security-severity": "6.9"}
            },
            {
              "id": "tachi/ai/llm",
              "name": "LLM",
              "shortDescription": {"text": "LLM-specific threats (prompt injection, output integrity, model theft)"},
              "properties": {"security-severity": "7.2"}
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "tachi/stride/spoofing",
          "message": {"text": "Attacker impersonates legitimate user via replayed session tokens [Control: missing]"},
          "level": "error",
          "locations": [{"logicalLocations": [{"name": "User", "kind": "component"}]}],
          "partialFingerprints": {"findingId/v1": "S-1"},
          "properties": {
            "security-severity": "7.9",
            "control-status": "missing",
            "control-evidence": [],
            "control-effectiveness": "none",
            "control-category": "authentication",
            "inherent-risk": "7.9",
            "residual-risk": "7.9",
            "maestro-layer": "L7 — Agent Ecosystem",
            "recommendation": "Implement session authentication with replay protection: short-lived JWT or opaque session tokens (5-15 min access, refresh-token rotation) bound to client IP and device fingerprint; MFA enrollment required; token revocation list checked on every request.",
            "effort-estimate": "High"
          }
        },
        {
          "ruleId": "tachi/stride/privilege-escalation",
          "message": {"text": "Prompt injection bypass elevates attacker to trusted Orchestrator caller [Control: missing]"},
