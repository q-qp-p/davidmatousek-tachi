{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "tachi-control-analyzer",
          "version": "1.0",
          "semanticVersion": "1.0",
          "informationUri": "https://github.com/owner/tachi",
          "rules": [
            {
              "id": "tachi/stride/spoofing",
              "shortDescription": { "text": "Identity spoofing threats" },
              "fullDescription": { "text": "Threats where an attacker pretends to be something or someone else, forging authentication credentials, replaying tokens, or impersonating trusted components to gain unauthorized access." },
              "properties": {
                "tags": ["security", "stride", "spoofing", "authentication"],
                "security-severity": "8.2"
              }
            },
            {
              "id": "tachi/stride/tampering",
              "shortDescription": { "text": "Data tampering threats" },
              "fullDescription": { "text": "Threats where an attacker modifies data, code, or configuration without authorization, violating integrity guarantees." },
              "properties": {
                "tags": ["security", "stride", "tampering", "data-integrity"],
                "security-severity": "7.1"
              }
            },
            {
              "id": "tachi/stride/repudiation",
              "shortDescription": { "text": "Repudiation threats" },
              "fullDescription": { "text": "Threats where a user or system can deny having performed an action, and the system lacks sufficient evidence to prove otherwise." },
              "properties": {
                "tags": ["security", "stride", "repudiation", "logging"],
                "security-severity": "5.9"
              }
            },
            {
              "id": "tachi/stride/information-disclosure",
              "shortDescription": { "text": "Information disclosure threats" },
              "fullDescription": { "text": "Threats where sensitive data is exposed to unauthorized parties through direct access, side-channels, or insufficient access controls." },
              "properties": {
                "tags": ["security", "stride", "information-disclosure", "confidentiality"],
                "security-severity": "7.2"
              }
            },
            {
              "id": "tachi/stride/denial-of-service",
              "shortDescription": { "text": "Denial of service threats" },
              "fullDescription": { "text": "Threats where an attacker exhausts system resources or disrupts availability, preventing legitimate users from accessing services." },
              "properties": {
                "tags": ["security", "stride", "denial-of-service", "availability"],
                "security-severity": "6.2"
              }
            },
            {
              "id": "tachi/stride/privilege-escalation",
              "shortDescription": { "text": "Privilege escalation threats" },
              "fullDescription": { "text": "Threats where an attacker gains elevated permissions beyond what is authorized, enabling access to restricted resources or actions." },
              "properties": {
                "tags": ["security", "stride", "privilege-escalation", "access-control"],
                "security-severity": "7.8"
              }
            },
            {
              "id": "tachi/ai/agentic",
              "shortDescription": { "text": "Agentic AI threats" },
              "fullDescription": { "text": "Threats specific to autonomous AI agents: excessive autonomy, tool abuse, inter-agent communication vulnerabilities, and cascading emergent behaviors." },
              "properties": {
                "tags": ["security", "ai", "agentic", "llm", "owasp-llm"],
                "security-severity": "7.8"
              }
            },
            {
              "id": "tachi/ai/llm",
              "shortDescription": { "text": "LLM-specific threats" },
              "fullDescription": { "text": "Threats targeting large language model behavior: prompt injection, training data poisoning, model theft, improper output handling, and misinformation." },
              "properties": {
                "tags": ["security", "ai", "llm", "prompt-injection", "owasp-llm"],
                "security-severity": "6.6"
              }
            }
          ]
        }
      },
