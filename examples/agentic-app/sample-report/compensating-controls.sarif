            "inherent-risk": "7.2",
            "residual-risk": "7.2",
            "maestro-layer": "L1 — Foundation Model",
            "recommendation": "Implement server-side output sanitization (DOMPurify/sanitize-html/bleach) plus strict Content-Security-Policy (default-src 'self'; script-src 'self' 'nonce-<nonce>'; object-src 'none'). Use textContent (not innerHTML); React as {value} JSX (never dangerouslySetInnerHTML).",
            "effort-estimate": "Medium"
          }
        },
        {
