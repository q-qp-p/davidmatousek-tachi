        {
          "ruleId": "tachi/stride/denial-of-service",
          "message": {
            "text": "The Knowledge Base can be rendered unavailable by an attacker who issues high-volume, complex vector search queries (exhaustive nearest-neighbor searches with high dimensionality). This degrades retrieval performance for the Orchestrator.",
            "markdown": "Implement per-session query rate limits and complexity bounds on vector search queries. Apply result caching for frequent queries. Monitor query throughput and reject queries that exceed complexity thresholds."
          },
