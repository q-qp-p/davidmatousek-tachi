{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "tachi-risk-scorer",
          "version": "1.0",
          "semanticVersion": "1.0",
          "informationUri": "https://github.com/owner/tachi",
          "supportedTaxonomies": [
            {
              "name": "OWASP-Top-10",
              "index": 0
            },
            {
              "name": "CWE",
              "index": 1
            }
          ],
          "rules": [
            {
              "id": "tachi/stride/spoofing",
              "name": "Spoofing",
              "shortDescription": { "text": "Identity or source impersonation" },
              "fullDescription": { "text": "Threats that involve an attacker assuming the identity of another user, process, or system component." },
              "properties": {
                "security-severity": "7.9",
                "tags": ["stride", "spoofing"]
              }
            },
            {
              "id": "tachi/stride/tampering",
              "name": "Tampering",
              "shortDescription": { "text": "Unauthorized modification of data or code" },
              "fullDescription": { "text": "Threats that involve unauthorized modification of data, configuration, or code in transit or at rest." },
              "properties": {
                "security-severity": "5.8",
                "tags": ["stride", "tampering"]
              }
            },
            {
              "id": "tachi/stride/repudiation",
              "name": "Repudiation",
              "shortDescription": { "text": "Inability to attribute actions" },
              "fullDescription": { "text": "Threats that involve an actor denying an action they performed, where the system cannot prove otherwise." },
              "properties": {
                "security-severity": "5.7",
                "tags": ["stride", "repudiation"]
              }
            },
            {
              "id": "tachi/stride/information-disclosure",
              "name": "Information Disclosure",
              "shortDescription": { "text": "Unauthorized data exposure" },
              "fullDescription": { "text": "Threats that involve the exposure of data to unauthorized parties." },
              "properties": {
                "security-severity": "5.5",
                "tags": ["stride", "information-disclosure"]
              }
            },
            {
              "id": "tachi/stride/denial-of-service",
              "name": "Denial of Service",
              "shortDescription": { "text": "Resource exhaustion or service disruption" },
              "fullDescription": { "text": "Threats that involve degrading or disrupting service availability for legitimate users." },
              "properties": {
                "security-severity": "6.6",
                "tags": ["stride", "denial-of-service"]
              }
            },
            {
              "id": "tachi/stride/elevation-of-privilege",
              "name": "Elevation of Privilege",
              "shortDescription": { "text": "Unauthorized privilege acquisition" },
              "fullDescription": { "text": "Threats that involve an attacker gaining capabilities or permissions they were not granted." },
              "properties": {
                "security-severity": "7.3",
                "tags": ["stride", "privilege-escalation"]
              }
            },
            {
              "id": "tachi/ai/agentic-threats",
              "name": "Agentic Threats",
              "shortDescription": { "text": "Agent autonomy and tool abuse threats" },
              "fullDescription": { "text": "Threats specific to agentic AI systems involving autonomous action execution, tool abuse, and multi-agent coordination." },
              "properties": {
                "security-severity": "6.9",
                "tags": ["ai", "agentic"]
              }
            },
            {
              "id": "tachi/ai/llm-threats",
              "name": "LLM Threats",
              "shortDescription": { "text": "LLM-specific threats" },
              "fullDescription": { "text": "Threats specific to large language model systems including prompt injection, data poisoning, model theft, and output-integrity execution sinks." },
              "properties": {
                "security-severity": "7.2",
                "tags": ["ai", "llm"]
              }
            }
          ]
        }
      },
