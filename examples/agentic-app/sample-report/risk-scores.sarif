        {
          "ruleId": "tachi/stride/denial-of-service",
          "message": {
            "text": "The Channel's message queue can be flooded by a compromised agent or a malfunctioning process, causing legitimate messages to be dropped, delayed, or rejected. Queue saturation disrupts coordination between Orchestrator and Specialist Agent.",
            "markdown": "Implement message queue depth limits and per-sender rate limits at the Channel layer. Apply backpressure mechanisms: when the queue approaches capacity, reject new messages from the sender with a rate-limit response. Monitor queue depth metrics."
          },
          "level": "warning",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "examples/agentic-app/test-output/2026-04-23T19-30-00-F2-wave4/threats.md" },
