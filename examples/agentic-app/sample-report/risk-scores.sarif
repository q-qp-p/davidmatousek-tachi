            "cvss_base": 10.0,
            "exploitability": 8.8,
            "scalability": 7.3,
            "reachability": 2.5,
            "composite": 7.7,
            "composite-weights": "0.35/0.30/0.15/0.20",
            "severity_band": "High",
            "cvss-base-score": "10.0",
            "cvss-vector": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:H",
            "maestro-layer": "L1 — Foundation Model",
