        {
          "ruleId": "tachi/stride/elevation-of-privilege",
          "message": {
            "text": "The Specialist Agent receives delegated permissions from the Orchestrator. If the delegation message is forged or tampered with (granting the Specialist elevated permissions beyond the original user session scope), the Specialist gains unauthorized capability to invoke tools or access data outside its permitted scope.",
            "markdown": "The MCP Tool Server MUST verify the Specialist's claimed permission scope against the originating user session's authorization at every tool invocation. Delegation messages MUST be validated against a central session-authorization record."
          },
          "level": "warning",
          "locations": [
