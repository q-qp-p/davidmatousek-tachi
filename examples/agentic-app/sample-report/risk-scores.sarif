          "partialFingerprints": {
            "findingId/v1": "D-2"
          },
          "properties": {
            "security-severity": "6.2",
            "cvss_base": 6.5,
            "exploitability": 8.0,
            "scalability": 7.0,
            "reachability": 2.5,
