        {
          "ruleId": "tachi/stride/information-disclosure",
          "message": {
            "text": "The Knowledge Base exposes its full document corpus to any process that can issue a vector search query. Without query-result access controls, a compromised Orchestrator or injected context can exfiltrate the entire corpus by issuing exhaustive search queries.",
            "markdown": "Implement query-result access controls: the Knowledge Base MUST enforce per-query result limits and per-session query budgets. Apply context-aware authorization to restrict retrieval to documents within the requesting session's permitted scope. Monitor for anomalous query patterns."
          },
          "level": "warning",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "examples/agentic-app/test-output/2026-04-23T19-30-00-F2-wave4/threats.md" },
