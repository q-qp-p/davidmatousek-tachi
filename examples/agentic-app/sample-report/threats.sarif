          "message": { "text": "An attacker may impersonate a legitimate user by replaying stolen session tokens or forging identity credentials to bypass authentication at the User-Guardrails boundary.", "markdown": "Implement short-lived JWT or session tokens with binding to client IP/device fingerprint. Enforce MFA for all user sessions." },
          "level": "error",
