        },
        {
          "ruleId": "tachi/stride/spoofing",
          "message": { "text": "The Inter-Agent Communication Channel is a shared routing substrate with no inherent sender authentication, enabling malicious process injection impersonating agents.", "markdown": "Implement per-message digital signatures (ED25519 or HMAC-SHA256) on all channel messages. Bind sender identity to each message envelope." },
          "level": "error",
          "locations": [{ "physicalLocation": { "artifactLocation": { "uri": "examples/agentic-app/architecture.md" }, "region": { "startLine": 1 } }, "logicalLocations": [{ "name": "Inter-Agent Communication Channel", "fullyQualifiedName": "Application Zone/Inter-Agent Communication Channel", "kind": "process" }] }],
