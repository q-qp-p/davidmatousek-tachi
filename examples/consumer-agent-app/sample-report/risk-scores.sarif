              "shortDescription": {
                "text": "Data tampering threats"
              },
              "fullDescription": {
                "text": "Threats where an attacker modifies data in transit, at rest, or in processing — including configuration, persona state, and audit log records."
              },
              "help": {
                "text": "Review integrity controls on all data flows, stored data, and inter-process messages.",
                "markdown": "Review integrity controls on all data flows.\n\n**References**: OWASP A08 (Software and Data Integrity Failures), CWE-345 (Insufficient Verification of Data Authenticity)"
              },
              "properties": {
                "tags": [
