  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "tachi-risk-scorer",
          "version": "1.0",
          "semanticVersion": "1.0",
          "informationUri": "https://github.com/davidmatousek/tachi",
          "supportedTaxonomies": [
            {
              "name": "OWASP",
              "index": 0
            },
            {
              "name": "CWE",
              "index": 1
            }
          ],
          "rules": [
            {
              "id": "tachi/ai/agentic-threats",
              "shortDescription": {
                "text": "AI agent autonomy and trust-exploitation threats"
              },
              "fullDescription": {
                "text": "Threats specific to AI agent frameworks — including agent autonomy boundary violations (ASI-01), tool-abuse (MCP-03/ASI-07), and human-trust-exploitation on consumer-facing AI Processes (OWASP ASI09:2026). The TE-{N} sub-class covers undisclosed AI authorship, authority-claim emission without confidence/source attestation, persuasive-tone manipulation, persona-boundary violations, and synthetic-relationship exploitation in vulnerable-population contexts."
              },
              "help": {
                "text": "Review agent scope enforcement, AI-disclosure mechanisms, confidence/source attestation, persuasion classifiers, persona discipline, and vulnerable-population safeguards.",
                "markdown": "Review agent scope and consumer-protection controls.\n\n**References**: OWASP Agentic Security Initiative (ASI-01, ASI-07, ASI09:2026), MCP Top 10 (MCP-03), CWE-223, CWE-287, CWE-290, CWE-345, CWE-693"
              },
              "properties": {
                "tags": [
                  "security",
                  "ai",
                  "agentic",
                  "human-trust-exploitation",
                  "asi09",
                  "cwe"
                ],
                "security-severity": "7.4"
              },
              "relationships": [
                {
                  "target": {
                    "id": "ASI09",
                    "toolComponent": {
                      "name": "OWASP"
                    }
                  },
                  "kinds": [
                    "relevant"
                  ]
                },
                {
                  "target": {
                    "id": "CWE-223",
                    "toolComponent": {
                      "name": "CWE"
                    }
                  },
                  "kinds": [
                    "relevant"
                  ]
                },
                {
                  "target": {
                    "id": "CWE-287",
                    "toolComponent": {
                      "name": "CWE"
                    }
                  },
                  "kinds": [
