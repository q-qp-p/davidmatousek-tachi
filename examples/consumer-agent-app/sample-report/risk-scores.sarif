                    }
                  },
                  "kinds": [
                    "relevant"
                  ]
                }
              ]
            },
            {
              "id": "tachi/stride/information-disclosure",
              "shortDescription": {
                "text": "Information disclosure threats"
              },
              "fullDescription": {
                "text": "Threats where sensitive data — including system prompts, persona state, conversation history, or user disclosures — is exposed to unauthorized parties."
              },
              "help": {
                "text": "Review access controls on all data stores and output paths.",
                "markdown": "Review access controls on data stores and outputs.\n\n**References**: OWASP A01 (Broken Access Control), CWE-200 (Exposure of Sensitive Information)"
              },
              "properties": {
                "tags": [
                  "security",
                  "stride",
                  "information-disclosure",
                  "data-exposure",
                  "owasp",
                  "cwe"
                ],
                "security-severity": "6.0"
              },
