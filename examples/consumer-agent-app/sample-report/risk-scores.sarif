                    "toolComponent": {
                      "name": "CWE"
                    }
                  },
                  "kinds": [
                    "relevant"
                  ]
                }
              ]
            },
            {
              "id": "tachi/stride/denial-of-service",
              "shortDescription": {
                "text": "Denial of service threats"
              },
              "fullDescription": {
                "text": "Threats where an attacker exhausts resources, disrupts service, or denies legitimate users access — including resource exhaustion attacks on AI inference and storage backends."
              },
              "help": {
                "text": "Review rate limiting, resource quotas, and circuit breakers.",
                "markdown": "Review availability controls.\n\n**References**: OWASP A04 (Insecure Design), CWE-693 (Protection Mechanism Failure)"
              },
              "properties": {
                "tags": [
                  "security",
                  "stride",
                  "denial-of-service",
                  "availability",
                  "owasp",
                  "cwe"
                ],
                "security-severity": "6.0"
              },
              "relationships": [
                {
                  "target": {
                    "id": "A04",
                    "toolComponent": {
                      "name": "OWASP"
                    }
                  },
                  "kinds": [
