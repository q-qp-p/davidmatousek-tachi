# Stack pack defaults for template placeholder replacement during make init
# These values auto-fill {{TECH_STACK_*}} and {{CLOUD_PROVIDER}} placeholders
TECH_STACK_DATABASE="Markdown+YAML"
TECH_STACK_VECTOR="N/A"
TECH_STACK_AUTH="N/A"
CLOUD_PROVIDER="local-filesystem"
# Informational metadata — documents the intended runtime environment
# Not a template placeholder processed by init.sh
ORCHESTRATION_TARGET="claude-code"
