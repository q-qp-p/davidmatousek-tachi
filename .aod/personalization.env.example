# =============================================================================
# .aod/personalization.env.example — tachi personalization template
# =============================================================================
# Copy this file to .aod/personalization.env and replace placeholder values
# with your real ones. `.aod/personalization.env` is gitignored (F-1 #248)
# so your real values stay local; this `.example` template is committed.
#
# These keys are consumed by scripts/init.sh and the F-2 substitution pipeline
# (.aod/scripts/bash/template-substitute.sh). Each key has a corresponding
# `{{KEY}}` placeholder in personalized template files.
#
# Substitution model: bash parameter expansion, NOT sed (per ADR-038 — the
# parameter-expansion approach handles `&`, `\`, `|` and other regex
# metacharacters correctly).
#
# Format: `KEY=value` — bash KV file convention. No quotes required (the
# loader strips them defensively). Comments: lines starting with `#` are
# ignored by aod_template_load_kv_file.
#
# This file is allow-listed in `.gitleaks.toml` so the placeholder values
# below do not trip the secret-scanning hook (F-5).
# =============================================================================

# Project identity ----------------------------------------------------------
AOD_PERSONALIZATION_PROJECT_NAME=PLACEHOLDER
AOD_PERSONALIZATION_PROJECT_DESCRIPTION=PLACEHOLDER
AOD_PERSONALIZATION_GITHUB_ORG=PLACEHOLDER
AOD_PERSONALIZATION_GITHUB_REPO=PLACEHOLDER

# AI agent + tech stack -----------------------------------------------------
AOD_PERSONALIZATION_AI_AGENT=PLACEHOLDER
AOD_PERSONALIZATION_TECH_STACK=PLACEHOLDER
AOD_PERSONALIZATION_TECH_STACK_AUTH=PLACEHOLDER
AOD_PERSONALIZATION_TECH_STACK_DATABASE=PLACEHOLDER
AOD_PERSONALIZATION_TECH_STACK_VECTOR=PLACEHOLDER
AOD_PERSONALIZATION_CLOUD_PROVIDER=PLACEHOLDER

# Date capture (init.sh sets these via `date +%Y-%m-%d` at first-run time)
AOD_PERSONALIZATION_CURRENT_DATE=PLACEHOLDER
AOD_PERSONALIZATION_RATIFICATION_DATE=PLACEHOLDER
