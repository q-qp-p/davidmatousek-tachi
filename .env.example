# Tachi Environment Configuration
# ============================================
#
# SETUP OPTIONS (pick one):
#
#   Option A — .env file (simplest)
#     cp .env.example .env
#     Edit .env with your real values
#     The .env file is gitignored and will never be committed
#
#   Option B — 1Password CLI (recommended)
#     Create ~/.claude/.env.tpl with op:// references:
#       GEMINI_API_KEY=op://YourVault/Gemini API Key/credential
#     Add a shell alias:
#       alias code='op run --env-file=$HOME/.claude/.env.tpl -- code'
#     See docs/security/OPEN_SOURCE_READINESS.md for full instructions
#
#   Option C — Export in your shell profile
#     Add to ~/.zshrc or ~/.bashrc:
#       export GEMINI_API_KEY=your_key_here
#
# ============================================

# ============================================
# Tachi Configuration
# ============================================

# Your GitHub org/repo (used by /aod.deliver for upstream sync)
AOD_REPO=davidmatousek/tachi

# ============================================
# Infographic Generation (optional)
# ============================================

# Required only for generating threat model infographic images (.jpg)
# Get a key at: https://aistudio.google.com/apikey
# Without this key, tachi still produces all text-based outputs
# (threats.md, threats.sarif, threat-report.md, attack trees)
GEMINI_API_KEY=your_gemini_api_key_here
