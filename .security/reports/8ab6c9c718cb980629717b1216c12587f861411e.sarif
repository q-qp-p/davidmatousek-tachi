          "partialFingerprints": {
            "primaryLocationLineHash": "f1f5431b147a13deb8db9f7c2cc305026ba8a6f47d5175b1ed3b89af22b8fc56"
          },
          "level": "note"
        },
        {
          "ruleId": "A05",
          "message": {
            "text": "The repository has no SECURITY.md file at the root. Security researchers who find vulnerabilities have no documented disclosure channel. GitHub auto-generates a 'Report a vulnerability' button when SECURITY.md is present and references its content. Absence is not a vulnerability per se but is a posture finding for an enterprise-hardening initiative \u2014 the very LinkedIn thread that triggered this scan is itself a public-disclosure incident that a SECURITY.md could have channeled into a private report."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "SECURITY.md"
                },
                "region": {
