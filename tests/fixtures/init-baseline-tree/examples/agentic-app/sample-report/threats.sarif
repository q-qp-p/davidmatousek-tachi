            "maestro-layer": "L6 \u2014 Security and Compliance",
            "severity": "High",
            "likelihood": "MEDIUM",
            "impact": "HIGH",
            "owasp_id": "A07"
          }
        },
        {
          "ruleId": "tachi/stride/spoofing",
          "message": {
            "text": "The Orchestrator's identity is not cryptographically attested to the Specialist Agent via the Inter-Agent Communication Channel. A compromised or rogue process could inject messages into the channel impersonating the Orchestrator, issuing unauthorized delegation instructions to the Specialist Agent.",
            "markdown": "Authenticate all Orchestrator\u2192Channel messages using HMAC or asymmetric signing with per-session keys. The Specialist Agent MUST verify the signature before acting on delegated tasks. Implement a nonce/replay-prevention field in every delegation message."
          },
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "examples/agentic-app/sample-report/threats.md"
                },
                "region": {
                  "startLine": 1
                }
