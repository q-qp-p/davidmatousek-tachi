        {
          "ruleId": "tachi/stride/spoofing",
          "message": {
            "text": "An attacker impersonates a legitimate user by replaying stolen session tokens or forging identity credentials to bypass authentication at the User\u2192Guardrails boundary, gaining unauthorized access to the system under a victim identity.",
            "markdown": "Implement short-lived JWT or session tokens with binding to client IP/device fingerprint. Enforce MFA for all user sessions. Use token revocation lists and refresh-token rotation with binding checks."
          },
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "examples/agentic-app/sample-report/threats.md"
                },
