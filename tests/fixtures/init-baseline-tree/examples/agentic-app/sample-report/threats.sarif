          }
        },
        {
          "ruleId": "tachi/stride/spoofing",
          "message": {
            "text": "The Specialist Agent impersonates the Orchestrator when returning results to the Inter-Agent Communication Channel. A compromised Specialist Agent could inject fabricated \"Aggregated Results\" back to the Orchestrator, making unauthorized actions appear to have originated from valid specialist work.",
            "markdown": "Sign all Specialist\u2192Channel messages with the Specialist's own identity key. The Orchestrator MUST verify the result's origin before incorporating it into its context or acting on it."
          },
          "level": "error",
          "locations": [
