        {
          "ruleId": "tachi/stride/repudiation",
          "message": { "text": "An End User could repudiate User Turn submissions if the architecture lacks non-repudiation evidence linking specific user inputs to specific authenticated identities at specific times.", "markdown": "Implement non-repudiation audit logging with cryptographic timestamps on every User Turn. Configure user-side attestation tokens (signed session identifiers) bound to authenticated identity." },
          "level": "warning",
          "locations": [{ "physicalLocation": { "artifactLocation": { "uri": "examples/consumer-agent-app/test-output/2023-11-14T22-13-20-F4-wave5/architecture.md" }, "region": { "startLine": 1 } }, "logicalLocations": [{ "name": "End User", "fullyQualifiedName": "User Zone/End User", "kind": "external-entity" }] }],
