        },
        {
          "ruleId": "tachi/stride/tampering",
          "message": { "text": "An attacker with database access could tamper with persisted persona state, modifying restored conversation context across user sessions — causing persona drift, injecting attacker-controlled context, or corrupting session memory.", "markdown": "Implement integrity-protected persona state (HMAC or digital signature on persisted records validated at restore time). Configure database access controls with least-privilege enforcement." },
          "level": "warning",
          "locations": [{ "physicalLocation": { "artifactLocation": { "uri": "examples/consumer-agent-app/test-output/2023-11-14T22-13-20-F4-wave5/architecture.md" }, "region": { "startLine": 1 } }, "logicalLocations": [{ "name": "Conversation Session Store", "fullyQualifiedName": "Application Zone/Conversation Session Store", "kind": "data-store" }] }],
