        },
        {
          "ruleId": "tachi/stride/tampering",
          "message": { "text": "An attacker with infrastructure access could tamper with the Interaction Audit Log, deleting or modifying interaction event records — compromising post-incident forensics, regulatory compliance, and dependency-risk analysis.", "markdown": "Implement append-only audit log architecture with cryptographic hash chaining. Configure write-once-read-many (WORM) storage backing." },
          "level": "warning",
          "locations": [{ "physicalLocation": { "artifactLocation": { "uri": "examples/consumer-agent-app/test-output/2023-11-14T22-13-20-F4-wave5/architecture.md" }, "region": { "startLine": 1 } }, "logicalLocations": [{ "name": "Interaction Audit Log", "fullyQualifiedName": "Application Zone/Interaction Audit Log", "kind": "data-store" }] }],
