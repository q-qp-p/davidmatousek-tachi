          },
          "properties": {
            "security-severity": "7.3",
            "cvss-base-score": "8.6",
            "cvss-vector": "CVSS:3.1/AV:N/AC:L/PR:L/UI:N/S:U/C:H/I:H/A:N",
            "exploitability": "7.3",
            "scalability": "8.3",
