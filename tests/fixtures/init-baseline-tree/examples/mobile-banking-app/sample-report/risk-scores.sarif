        {
          "ruleId": "tachi/stride/spoofing",
          "message": {
            "text": "Long-Lived Session Token Replay: Auth tokens persisted on device without rotation policy or revocation trigger. An attacker obtaining the token can replay it indefinitely with no expiry enforcement.",
            "markdown": "Enforce short-lived session tokens (max 15 min TTL); implement refresh token rotation with revocation on suspicious signals (new device, unusual location). References: OWASP A07:2021; CWE-613"
          },
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "examples/mobile-banking-app/architecture.md"
                },
                "region": {
                  "startLine": 1
                }
              },
              "logicalLocation": {
                "name": "Mobile Banking Customer",
                "fullyQualifiedName": "User Zone/Mobile Banking Customer",
                "kind": "process"
              }
            }
          ],
          "partialFingerprints": {
            "findingId/v1": "S-5"
          },
          "properties": {
            "security-severity": "9.3",
            "cvss-base-score": "9.8",
            "cvss-vector": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:N",
            "exploitability": "9.0",
