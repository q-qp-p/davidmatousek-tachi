          },
          "properties": {
            "security-severity": "8.1",
            "cvss-base-score": "9.3",
            "cvss-vector": "CVSS:3.1/AV:L/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:N",
            "exploitability": "8.8",
            "scalability": "8.5",
            "reachability": "4.5",
            "composite-weights": "0.35/0.30/0.15/0.20",
            "severity-band": "High",
