              }
            }
          ],
          "partialFingerprints": {
            "findingId/v1": "I-4"
          },
          "properties": {
            "security-severity": "7.5",
            "cvss-base-score": "7.7",
            "cvss-vector": "CVSS:3.1/AV:L/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:N",
            "exploitability": "9.0",
            "scalability": "8.3",
