          },
          "properties": {
            "security-severity": "7.7",
            "cvss-base-score": "9.3",
            "cvss-vector": "CVSS:3.1/AV:L/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:N",
            "exploitability": "7.8",
