{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Tachi-ControlAnalyzer",
          "semanticVersion": "1.0",
          "informationUri": "https://github.com/davidmatousek/tachi"
        }
      },
      "results": [
        {"ruleId": "tachi/control/missing", "level": "error", "message": {"text": "S-1: Merchant Transaction Submitter — No Control Found. Composite 8.4 inherent / 8.4 residual. Recommendation: short-lived OAuth/JWT bound to IP+device fingerprint; mTLS at boundary."}, "properties": {"id": "S-1", "control_status": "Not Found", "inherent_composite": 8.4, "residual_composite": 8.4, "severity": "Critical", "security-severity": "8.4"}},
        {"ruleId": "tachi/control/missing", "level": "error", "message": {"text": "T-10: FraudDetectionML Prediction API — Adversarial Input Manipulation (Pattern Category 10, OWASP ML01:2023). Composite 7.6 inherent / 7.6 residual. Recommendation: adversarial training + statistical-anomaly detection + ensemble disagreement + HITL escalation."}, "properties": {"id": "T-10", "owasp_references": ["OWASP ML01:2023"], "control_status": "Not Found", "inherent_composite": 7.6, "residual_composite": 7.6, "severity": "High", "security-severity": "7.6"}},
        {"ruleId": "tachi/control/missing", "level": "error", "message": {"text": "LLM-1: FraudDetectionML Prediction API — Model Inversion (Pattern Category 12, OWASP ML03:2023). Composite 7.4 inherent / 7.4 residual. Recommendation: DP-SGD + output-perturbation noise + per-tenant query-rate throttling + extraction-pattern detection."}, "properties": {"id": "LLM-1", "owasp_references": ["OWASP ML03:2023"], "control_status": "Not Found", "inherent_composite": 7.4, "residual_composite": 7.4, "severity": "High", "security-severity": "7.4"}},
        {"ruleId": "tachi/control/missing", "level": "error", "message": {"text": "LLM-2: FraudDetectionML Prediction API — Membership Inference (Pattern Category 13, OWASP ML04:2023). Composite 7.4 inherent / 7.4 residual. Recommendation: DP-SGD + confidence-output truncation + label-only mode + training-data minimization."}, "properties": {"id": "LLM-2", "owasp_references": ["OWASP ML04:2023"], "control_status": "Not Found", "inherent_composite": 7.4, "residual_composite": 7.4, "severity": "High", "security-severity": "7.4"}},
        {"ruleId": "tachi/control/missing", "level": "error", "message": {"text": "LLM-3: MLflow Model Registry — Predictive-ML Artifact Supply Chain (Pattern Category 14, OWASP ML06:2023, artifact-side). Composite 7.4 inherent / 7.4 residual. Recommendation: signed-artifact policy + PR review + load-time integrity verification."}, "properties": {"id": "LLM-3", "owasp_references": ["OWASP ML06:2023"], "control_status": "Not Found", "inherent_composite": 7.4, "residual_composite": 7.4, "severity": "High", "security-severity": "7.4"}},
        {"ruleId": "tachi/control/missing", "level": "error", "message": {"text": "LLM-4: Weight Checkpoint Storage — Predictive-ML Artifact Supply Chain (Pattern Category 14). Composite 7.4 inherent / 7.4 residual. Recommendation: WORM policy + audit logging + SHA-256 verification at load time."}, "properties": {"id": "LLM-4", "owasp_references": ["OWASP ML06:2023"], "control_status": "Not Found", "inherent_composite": 7.4, "residual_composite": 7.4, "severity": "High", "security-severity": "7.4"}},
        {"ruleId": "tachi/control/missing", "level": "error", "message": {"text": "D-8: Fine-Tuning Service — Transfer Learning Supply Chain (Pattern Category 8, OWASP ML07:2023). Composite 7.3 inherent / 7.3 residual. Recommendation: revision-pinning + signed-weight-artifact policy + allowlist + model-card review."}, "properties": {"id": "D-8", "owasp_references": ["OWASP ML07:2023"], "control_status": "Not Found", "inherent_composite": 7.3, "residual_composite": 7.3, "severity": "High", "security-severity": "7.3"}},
        {"ruleId": "tachi/control/missing", "level": "error", "message": {"text": "D-9: Active-Learning Feedback Loop — Feedback-Loop Model Skewing (Pattern Category 9, OWASP ML08:2023). Composite 7.1 inherent / 7.1 residual. Recommendation: feedback-data integrity gates + labeler-trust scoring + held-out canary set + drift-detection alarms."}, "properties": {"id": "D-9", "owasp_references": ["OWASP ML08:2023"], "control_status": "Not Found", "inherent_composite": 7.1, "residual_composite": 7.1, "severity": "High", "security-severity": "7.1"}},
        {"ruleId": "tachi/control/missing", "level": "error", "message": {"text": "D-10: Model Training Pipeline — Predictive-ML Corpus Supply Chain (Pattern Category 10, OWASP ML06:2023, corpus-side). Composite 7.4 inherent / 7.4 residual. Recommendation: dataset-checksum manifest + IAM-enforced write-audit + model-card review as promotion gate."}, "properties": {"id": "D-10", "owasp_references": ["OWASP ML06:2023"], "control_status": "Not Found", "inherent_composite": 7.4, "residual_composite": 7.4, "severity": "High", "security-severity": "7.4"}},
        {"ruleId": "tachi/control/missing", "level": "error", "message": {"text": "D-11: Feast Feature Store — Predictive-ML Corpus Supply Chain (Pattern Category 10). Composite 7.1 inherent / 7.1 residual. Recommendation: IAM with per-write audit + feature-vector integrity verification at read time."}, "properties": {"id": "D-11", "owasp_references": ["OWASP ML06:2023"], "control_status": "Not Found", "inherent_composite": 7.1, "residual_composite": 7.1, "severity": "High", "security-severity": "7.1"}}
      ]
    }
  ]
}
