{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Tachi",
          "semanticVersion": "1.4",
          "informationUri": "https://github.com/davidmatousek/tachi",
          "rules": [
            {
              "id": "tachi/stride/spoofing",
              "shortDescription": {"text": "Identity spoofing threats"},
              "fullDescription": {"text": "Threats where an attacker assumes the identity of another user, service, or component to gain unauthorized access or bypass authentication controls."},
              "properties": {"tags": ["security", "stride", "spoofing"], "security-severity": "9.0"}
            },
            {
              "id": "tachi/stride/tampering",
              "shortDescription": {"text": "Data and integrity tampering threats"},
              "fullDescription": {"text": "Threats where data, code, or messages are modified without authorization, including supply-chain integrity gaps and adversarial-input manipulation against deployed predictive ML classifiers (F-6 Pattern Category 10, OWASP ML01:2023)."},
              "properties": {"tags": ["security", "stride", "tampering", "owasp-ml01-2023"], "security-severity": "9.0"}
            },
            {
              "id": "tachi/stride/repudiation",
              "shortDescription": {"text": "Action repudiation threats"},
              "fullDescription": {"text": "Threats where an actor denies having performed an action, due to insufficient logging or non-repudiable evidence."},
              "properties": {"tags": ["security", "stride", "repudiation"], "security-severity": "5.0"}
            },
            {
              "id": "tachi/stride/info-disclosure",
              "shortDescription": {"text": "Information disclosure threats"},
              "fullDescription": {"text": "Threats where sensitive data is leaked to unauthorized parties."},
              "properties": {"tags": ["security", "stride", "info-disclosure"], "security-severity": "7.0"}
            },
            {
              "id": "tachi/stride/dos",
              "shortDescription": {"text": "Denial of service threats"},
              "fullDescription": {"text": "Threats where availability is degraded or denied through resource exhaustion."},
              "properties": {"tags": ["security", "stride", "dos"], "security-severity": "7.0"}
            },
            {
              "id": "tachi/stride/elevation",
              "shortDescription": {"text": "Privilege elevation threats"},
              "fullDescription": {"text": "Threats where an actor gains unauthorized capabilities beyond their granted permissions."},
              "properties": {"tags": ["security", "stride", "elevation"], "security-severity": "9.0"}
            },
            {
              "id": "tachi/llm/data-poisoning",
              "shortDescription": {"text": "Data poisoning threats"},
              "fullDescription": {"text": "Threats where training data, fine-tuning artifacts, or feedback loops are manipulated. F-6 Pattern Categories 8 (Transfer Learning Supply Chain, OWASP ML07:2023), 9 (Feedback-Loop Model Skewing, OWASP ML08:2023), 10 (Predictive-ML Corpus Supply Chain, OWASP ML06:2023 corpus-side facet)."},
              "properties": {"tags": ["security", "ai", "data-poisoning", "owasp-ml06-2023", "owasp-ml07-2023", "owasp-ml08-2023"], "security-severity": "9.0"}
            },
            {
              "id": "tachi/llm/model-theft",
              "shortDescription": {"text": "Model theft and extraction threats"},
              "fullDescription": {"text": "Threats where model weights, training data, or inference outputs are exfiltrated. F-6 Pattern Categories 12 (Model Inversion, OWASP ML03:2023), 13 (Membership Inference, OWASP ML04:2023), 14 (Predictive-ML Artifact Supply Chain, OWASP ML06:2023 artifact-side facet)."},
              "properties": {"tags": ["security", "ai", "model-theft", "owasp-ml03-2023", "owasp-ml04-2023", "owasp-ml06-2023"], "security-severity": "9.0"}
            }
          ]
        }
      },
      "results": [
        {"ruleId": "tachi/stride/spoofing", "ruleIndex": 0, "level": "error", "message": {"text": "S-1: Merchant Transaction Submitter — Token replay/spoofing on prediction-API trust-boundary crossing."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 9}}, "logicalLocations": [{"name": "Merchant Transaction Submitter", "kind": "component"}]}], "properties": {"id": "S-1", "category": "spoofing", "component": "Merchant Transaction Submitter", "risk_level": "Critical", "likelihood": "HIGH", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/spoofing", "ruleIndex": 0, "level": "error", "message": {"text": "S-2: Fraud Analyst — Compromised analyst account spoofing for audit-log harvesting."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 10}}, "logicalLocations": [{"name": "Fraud Analyst", "kind": "component"}]}], "properties": {"id": "S-2", "category": "spoofing", "component": "Fraud Analyst", "risk_level": "High", "likelihood": "MEDIUM", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/spoofing", "ruleIndex": 0, "level": "error", "message": {"text": "S-3: FraudDetectionML Prediction API — Rogue Application-Zone process spoofs prediction API identity."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 18}}, "logicalLocations": [{"name": "FraudDetectionML Prediction API", "kind": "component"}]}], "properties": {"id": "S-3", "category": "spoofing", "component": "FraudDetectionML Prediction API", "risk_level": "High", "likelihood": "MEDIUM", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/spoofing", "ruleIndex": 0, "level": "error", "message": {"text": "S-4: Model Training Pipeline — Service account spoofing to ingest poisoned training data."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 19}}, "logicalLocations": [{"name": "Model Training Pipeline", "kind": "component"}]}], "properties": {"id": "S-4", "category": "spoofing", "component": "Model Training Pipeline", "risk_level": "High", "likelihood": "MEDIUM", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/spoofing", "ruleIndex": 0, "level": "error", "message": {"text": "S-5: Fine-Tuning Service — Same-named upstream maintainer spoofing on HuggingFace Hub."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 20}}, "logicalLocations": [{"name": "Fine-Tuning Service", "kind": "component"}]}], "properties": {"id": "S-5", "category": "spoofing", "component": "Fine-Tuning Service", "risk_level": "Critical", "likelihood": "HIGH", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/spoofing", "ruleIndex": 0, "level": "error", "message": {"text": "S-6: HuggingFace Hub — Network-level DNS/BGP hijack to attacker-controlled mirror."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 35}}, "logicalLocations": [{"name": "HuggingFace Hub Pretrained-Weights Registry", "kind": "component"}]}], "properties": {"id": "S-6", "category": "spoofing", "component": "HuggingFace Hub Pretrained-Weights Registry", "risk_level": "High", "likelihood": "MEDIUM", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/tampering", "ruleIndex": 1, "level": "error", "message": {"text": "T-1: FraudDetectionML Prediction API — Generic input-tampering at the API boundary."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 18}}, "logicalLocations": [{"name": "FraudDetectionML Prediction API", "kind": "component"}]}], "properties": {"id": "T-1", "category": "tampering", "component": "FraudDetectionML Prediction API", "risk_level": "High", "likelihood": "MEDIUM", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/tampering", "ruleIndex": 1, "level": "error", "message": {"text": "T-2: Model Training Pipeline — Tampered training corpus without checksum manifest."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 19}}, "logicalLocations": [{"name": "Model Training Pipeline", "kind": "component"}]}], "properties": {"id": "T-2", "category": "tampering", "component": "Model Training Pipeline", "risk_level": "Critical", "likelihood": "HIGH", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/tampering", "ruleIndex": 1, "level": "error", "message": {"text": "T-3: Internal Merchant Transaction History — Training-corpus mutation without IAM-enforced write-audit."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 28}}, "logicalLocations": [{"name": "Internal Merchant Transaction History", "kind": "component"}]}], "properties": {"id": "T-3", "category": "tampering", "component": "Internal Merchant Transaction History", "risk_level": "Critical", "likelihood": "HIGH", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/tampering", "ruleIndex": 1, "level": "error", "message": {"text": "T-4: Feast Feature Store — Feature-vector mutation without IAM-enforced write-audit."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 29}}, "logicalLocations": [{"name": "Feast Feature Store", "kind": "component"}]}], "properties": {"id": "T-4", "category": "tampering", "component": "Feast Feature Store", "risk_level": "Critical", "likelihood": "HIGH", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/tampering", "ruleIndex": 1, "level": "error", "message": {"text": "T-5: MLflow Model Registry — Backdoored artifact promotion without signed-artifact policy."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 30}}, "logicalLocations": [{"name": "MLflow Model Registry", "kind": "component"}]}], "properties": {"id": "T-5", "category": "tampering", "component": "MLflow Model Registry", "risk_level": "Critical", "likelihood": "HIGH", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/tampering", "ruleIndex": 1, "level": "error", "message": {"text": "T-6: Weight Checkpoint Storage — In-place weight overwrite on mutable storage."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 31}}, "logicalLocations": [{"name": "Weight Checkpoint Storage", "kind": "component"}]}], "properties": {"id": "T-6", "category": "tampering", "component": "Weight Checkpoint Storage", "risk_level": "Critical", "likelihood": "HIGH", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/tampering", "ruleIndex": 1, "level": "error", "message": {"text": "T-7: Interaction Audit Log — Audit-log entry tampering."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 23}}, "logicalLocations": [{"name": "Interaction Audit Log", "kind": "component"}]}], "properties": {"id": "T-7", "category": "tampering", "component": "Interaction Audit Log", "risk_level": "High", "likelihood": "MEDIUM", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/tampering", "ruleIndex": 1, "level": "error", "message": {"text": "T-8: Fine-Tuning Service — Poisoned upstream pretrained-weights merged at fine-tune."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 20}}, "logicalLocations": [{"name": "Fine-Tuning Service", "kind": "component"}]}], "properties": {"id": "T-8", "category": "tampering", "component": "Fine-Tuning Service", "risk_level": "Critical", "likelihood": "HIGH", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/tampering", "ruleIndex": 1, "level": "error", "message": {"text": "T-9: Active-Learning Feedback Loop — Label-flip via labeling worker without trust-scoring."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 21}}, "logicalLocations": [{"name": "Active-Learning Feedback Loop", "kind": "component"}]}], "properties": {"id": "T-9", "category": "tampering", "component": "Active-Learning Feedback Loop", "risk_level": "Critical", "likelihood": "HIGH", "impact": "HIGH"}},
        {"ruleId": "tachi/stride/tampering", "ruleIndex": 1, "level": "error", "message": {"text": "T-10: FraudDetectionML Prediction API — Adversarial Input Manipulation (Predictive ML, Pattern Category 10, OWASP ML01:2023). The deployed classifier ingests raw user-controlled features without input-validation barrier or adversarial-defense controls. AML.T0015 prose-only."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 18}}, "logicalLocations": [{"name": "FraudDetectionML Prediction API", "kind": "component"}]}], "properties": {"id": "T-10", "category": "tampering", "pattern_category": 10, "owasp_references": ["OWASP ML01:2023"], "cwe_references": ["CWE-20", "CWE-1039"], "component": "FraudDetectionML Prediction API", "risk_level": "Critical", "likelihood": "HIGH", "impact": "HIGH", "source_attribution": ["OWASP-ML01-2023"]}},
        {"ruleId": "tachi/stride/repudiation", "ruleIndex": 2, "level": "warning", "message": {"text": "R-1: Merchant Transaction Submitter — Transaction-submission denial."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 9}}, "logicalLocations": [{"name": "Merchant Transaction Submitter", "kind": "component"}]}], "properties": {"id": "R-1", "category": "repudiation", "component": "Merchant Transaction Submitter", "risk_level": "Medium"}},
        {"ruleId": "tachi/stride/repudiation", "ruleIndex": 2, "level": "note", "message": {"text": "R-2: Fraud Analyst — Audit-query denial."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 10}}, "logicalLocations": [{"name": "Fraud Analyst", "kind": "component"}]}], "properties": {"id": "R-2", "category": "repudiation", "component": "Fraud Analyst", "risk_level": "Low"}},
        {"ruleId": "tachi/stride/repudiation", "ruleIndex": 2, "level": "warning", "message": {"text": "R-3: FraudDetectionML Prediction API — Prediction-response denial."}, "properties": {"id": "R-3", "category": "repudiation", "component": "FraudDetectionML Prediction API", "risk_level": "High"}},
        {"ruleId": "tachi/stride/repudiation", "ruleIndex": 2, "level": "warning", "message": {"text": "R-4: Model Training Pipeline — Training-output provenance denial."}, "properties": {"id": "R-4", "category": "repudiation", "component": "Model Training Pipeline", "risk_level": "High"}},
