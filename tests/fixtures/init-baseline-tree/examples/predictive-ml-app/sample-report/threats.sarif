        {"ruleId": "tachi/stride/info-disclosure", "ruleIndex": 3, "level": "warning", "message": {"text": "I-2: Model Training Pipeline — Memorized PII via inversion/membership-inference vulnerability."}, "properties": {"id": "I-2", "category": "info-disclosure", "component": "Model Training Pipeline", "risk_level": "High"}},
        {"ruleId": "tachi/stride/info-disclosure", "ruleIndex": 3, "level": "warning", "message": {"text": "I-3: Internal Merchant Transaction History — Merchant-PII exposed without scoped read access."}, "properties": {"id": "I-3", "category": "info-disclosure", "component": "Internal Merchant Transaction History", "risk_level": "High"}},
        {"ruleId": "tachi/stride/info-disclosure", "ruleIndex": 3, "level": "note", "message": {"text": "I-4: Feast Feature Store — Engineered-feature leakage."}, "properties": {"id": "I-4", "category": "info-disclosure", "component": "Feast Feature Store", "risk_level": "Low"}},
        {"ruleId": "tachi/stride/info-disclosure", "ruleIndex": 3, "level": "warning", "message": {"text": "I-5: MLflow Model Registry — Training-recipe metadata leakage."}, "properties": {"id": "I-5", "category": "info-disclosure", "component": "MLflow Model Registry", "risk_level": "Medium"}},
        {"ruleId": "tachi/stride/info-disclosure", "ruleIndex": 3, "level": "warning", "message": {"text": "I-6: Interaction Audit Log — Operational-history exposure."}, "properties": {"id": "I-6", "category": "info-disclosure", "component": "Interaction Audit Log", "risk_level": "High"}},
        {"ruleId": "tachi/stride/info-disclosure", "ruleIndex": 3, "level": "warning", "message": {"text": "I-7: Active-Learning Feedback Loop — Merchant-PII propagation through labeling queue."}, "properties": {"id": "I-7", "category": "info-disclosure", "component": "Active-Learning Feedback Loop", "risk_level": "High"}},
        {"ruleId": "tachi/stride/dos", "ruleIndex": 4, "level": "error", "message": {"text": "D-1: FraudDetectionML Prediction API — Inference-endpoint flooding without per-tenant rate limit."}, "properties": {"id": "D-1", "category": "dos", "component": "FraudDetectionML Prediction API", "risk_level": "Critical"}},
        {"ruleId": "tachi/stride/dos", "ruleIndex": 4, "level": "warning", "message": {"text": "D-2: Model Training Pipeline — Training-job concurrency exhaustion."}, "properties": {"id": "D-2", "category": "dos", "component": "Model Training Pipeline", "risk_level": "Medium"}},
