        {"ruleId": "tachi/llm/model-theft", "ruleIndex": 7, "level": "error", "message": {"text": "LLM-1: FraudDetectionML Prediction API — Model Inversion (Predictive ML, Pattern Category 12, OWASP ML03:2023). DP-SGD absent; output-perturbation noise absent; query-rate throttling absent; extraction-pattern detection absent. AML.T0024 catalog reference."}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "examples/predictive-ml-app/architecture.md"}, "region": {"startLine": 18}}, "logicalLocations": [{"name": "FraudDetectionML Prediction API", "kind": "component"}]}], "properties": {"id": "LLM-1", "category": "model-theft", "pattern_category": 12, "owasp_references": ["OWASP ML03:2023"], "atlas_references": ["AML.T0024"], "component": "FraudDetectionML Prediction API", "risk_level": "Critical", "likelihood": "HIGH", "impact": "HIGH", "source_attribution": ["OWASP-ML03-2023", "AML-T0024"]}},
