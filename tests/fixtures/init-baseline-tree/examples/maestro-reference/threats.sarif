          "message": { "text": "An attacker may spoof the Physician Clinical Portal to intercept clinical recommendation responses from the Supervisor Orchestrator, receiving sensitive patient data intended for legitimate physicians.", "markdown": "Enforce server certificate pinning and signed response tokens. Validate portal origin on all supervisor-to-portal responses." },
          "level": "error",
