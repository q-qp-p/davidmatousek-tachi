        },
        {
          "ruleId": "tachi/ai/agentic-threats",
          "message": { "text": "The architecture includes Outcomes Telemetry and Physician Override Audit Store — a persistent-state component (long-running learning loop) that enables temporal attacks: sleeper agents activated by delayed triggers, gradual corruption below detection thresholds, and seasonal exploitation patterns. Recommended controls: training-data provenance attestation, memory-write audit trails, and periodic behavioral baselining against pre-training snapshots.", "markdown": "Implement training-data provenance attestation on all physician-override records before ingestion into the learning loop. Apply memory-write audit trails on all Outcomes Telemetry writes. Perform periodic behavioral baselining of Clinical LLM and Supervisor Orchestrator against pre-training reference snapshots to detect temporal drift." },
          "level": "error",
          "locations": [{ "physicalLocation": { "artifactLocation": { "uri": "examples/maestro-reference/architecture.md" }, "region": { "startLine": 1 } }, "logicalLocations": [{ "name": "Outcomes Telemetry and Physician Override Audit Store", "fullyQualifiedName": "Evaluation and Observability Zone (L5)/Outcomes Telemetry and Physician Override Audit Store", "kind": "data-store" }] }],
