        },
        {
          "ruleId": "tachi/stride/spoofing",
          "message": { "text": "An attacker may submit fraudulent EHR update events by spoofing a patient identity, injecting false patient records into the ingestion pipeline.", "markdown": "Validate EHR update events against an authoritative patient identity registry before enqueuing. Use cryptographic patient identity tokens on all ingestion events." },
          "level": "error",
