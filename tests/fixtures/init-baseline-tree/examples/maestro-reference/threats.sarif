        {
          "ruleId": "tachi/ai/agentic-threats",
          "message": { "text": "Two or more agentic components in Inter-Agent Communication Channel coordinate over an inter-agent data flow, creating a potential for coordinated malicious action. Compromised agents could jointly exfiltrate data, split prohibited actions across peers, or issue coordinated tool calls that individually fall below per-agent detection thresholds. Recommended controls: inter-agent rate limits, coordination throttles, and per-flow audit logging.", "markdown": "Implement inter-agent rate limits and coordination throttles on the Inter-Agent Communication Channel. Apply per-flow audit logging linking all coordinated messages to originating agents. Monitor for coordination patterns below per-agent detection thresholds." },
          "level": "error",
          "locations": [{ "physicalLocation": { "artifactLocation": { "uri": "examples/maestro-reference/architecture.md" }, "region": { "startLine": 1 } }, "logicalLocations": [{ "name": "Inter-Agent Communication Channel", "fullyQualifiedName": "Agent Ecosystem Zone (L7)/Inter-Agent Communication Channel", "kind": "process" }] }],
