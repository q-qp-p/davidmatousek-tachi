        },
        {
          "ruleId": "tachi/ai/agentic-threats",
          "message": { "text": "Multi-agent interactions in Supervisor Orchestrator exhibit the potential for emergent behavior — cascading failures, feedback amplification, or collective optimization that bypasses per-agent safety evaluation. Recommended controls: fail-safe shutdown circuits, bounded action scopes per agent, and behavioral baselining of the collective agent system.", "markdown": "Implement fail-safe shutdown circuits at the Supervisor Orchestrator that halt delegation on anomalous specialist response patterns. Apply bounded action scopes per agent per clinical session. Perform behavioral baselining of the collective agent system (Supervisor + Diagnostic Agent + Treatment Planner Agent) to detect emergent coordination patterns invisible to per-agent monitoring." },
          "level": "error",
          "locations": [{ "physicalLocation": { "artifactLocation": { "uri": "examples/maestro-reference/architecture.md" }, "region": { "startLine": 1 } }, "logicalLocations": [{ "name": "Supervisor Orchestrator", "fullyQualifiedName": "Agent Frameworks Zone (L3)/Supervisor Orchestrator", "kind": "process" }] }],
