# Environment Variables — Development Defaults
#
# Copy this file to .env before running docker compose:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git. Only .env.example is tracked.

# ---------- Database ----------
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app_dev
DATABASE_URL=postgresql+asyncpg://app:changeme@db:5432/app_dev

# ---------- Security ----------
# Generate a real secret for staging/production:
#   openssl rand -base64 32
SECRET_KEY=change-this-to-a-random-secret-key

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:5173"]

# ---------- Frontend ----------
VITE_API_URL=http://localhost:8000/api/v1

# ---------- App ----------
DEBUG=true
