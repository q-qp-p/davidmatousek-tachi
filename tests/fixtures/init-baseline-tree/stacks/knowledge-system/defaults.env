# Stack pack defaults for template placeholder replacement during make init
# These values auto-fill {{TECH_STACK_*}} and Not yet defined placeholders
# Canonical 5-key surface per contracts/stack-pack-defaults-schema.md
# (F-2 BLP-02 Wave 2 — TECH_STACK added to align with STACK_PACK_ALLOWED_KEYS;
#  ORCHESTRATION_TARGET removed because it was informational metadata never
#  processed by init.sh, and the canonical whitelist rejects extra keys).
TECH_STACK="knowledge-system"
TECH_STACK_DATABASE="Markdown+YAML"
TECH_STACK_VECTOR="N/A"
TECH_STACK_AUTH="N/A"
CLOUD_PROVIDER="local-filesystem"
