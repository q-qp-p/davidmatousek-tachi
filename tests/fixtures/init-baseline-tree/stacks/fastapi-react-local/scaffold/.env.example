# Environment Variables — Development Defaults
#
# Copy this file to .env before running the application:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git. Only .env.example is tracked.

# ---------- Database ----------
# SQLite (default — no external services needed)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ---------- Security ----------
# Generate a real secret for staging/production:
#   openssl rand -base64 32
SECRET_KEY=change-this-to-a-random-secret-key

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:5173"]

# ---------- Frontend ----------
VITE_API_URL=http://localhost:8000/api/v1

# ---------- App ----------
DEBUG=true
